# Clerk (https://dashboard.clerk.com/last-active?path=api-keys)
# REQUIRED — empty keys trigger keyless mode and "Too many requests" login errors
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Disable temporary keyless mode (recommended for local dev once you have keys)
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED=true

# OpenAI (optional — app uses deterministic mock pipeline when unset)
# OPENAI_API_KEY=sk-...
